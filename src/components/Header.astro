---
import astroLogo from '../assets/logo-e-responsable.svg';
---

<header class="header">
    <a class="header-logo" href="https://astro.build">
        <img src={astroLogo.src} height="38" alt="Astro" />
    </a>
    <nav>
        <a class="button" href="/services/">Nos Services</a>
        <a class="button" href="/services/">Eco-conception</a>
        <a class="button" href="/services/">Etudes de cas</a>
    </nav>
</header>

<style>
.header {
    position: fixed;
    background: white;
    width: 100%;
    display: flex;
    align-items: center;
    border: 1px solid black;

    .header-logo {
        padding: 30px 40px;
        border-right: 1px solid black;
    }

    nav {
        padding: 30px 40px;
        border-right: 1px solid black;
        display: flex;
        gap: 20px;

        a { 
            color: black;
            text-decoration: none;  
            font-size: 20px;
        }
    }
}
</style>